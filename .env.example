# ════════════════════════════════════════════════════════
#  BCI v1.0 — Behavioral Commitment Identity on Starknet
#  Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit your .env file to version control.
# ════════════════════════════════════════════════════════

# ── RPC Endpoint ─────────────────────────────────────────
# Sepolia (testnet) — default free endpoint:
RPC_URL=https://free-rpc.nethermind.io/sepolia-juno

# Mainnet — replace with your paid endpoint for production:
# RPC_URL=https://free-rpc.nethermind.io/mainnet-juno
# RPC_URL=https://starknet-mainnet.infura.io/v3/YOUR_INFURA_KEY
# RPC_URL=https://starknet-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Contract Address ──────────────────────────────────────
# The deployed BCIAgentIdentity contract address.
# After deploying with sncast (see README), paste the address here.
#
# Sepolia (testnet):
CONTRACT_ADDRESS=0x

# Mainnet (production):
# CONTRACT_ADDRESS=0x

# ── Starknet Account ──────────────────────────────────────
# Your Starknet account address.
# This account MUST be set as the `relayer` in the constructor.
# For the demo, your account acts as both owner and relayer.
ACCOUNT_ADDRESS=0x

# ── Private Key ───────────────────────────────────────────
# Your Starknet account private key.
# ⚠️  KEEP THIS SECRET — never share or commit it.
PRIVATE_KEY=0x

# ── Global Agent ID (optional) ───────────────────────────
# Set this ONLY after complete_enrollment() has been confirmed on-chain.
# Leave blank on first run — the demo will tell you what to set here.
#
# Accepts two formats:
#   1. Hex felt252:  0x03f2a7b...   (exact on-chain key)
#   2. Friendly name: my-agent      (hashed deterministically via SHA-256 → felt252)
#      Same name always resolves to the same felt252 across every run.
#
# Example:
# GLOBAL_AGENT_ID=my-ziondefi-agent
GLOBAL_AGENT_ID=
